// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Apartment {
  id           String   @id @default(uuid())
  name         String
  address      String
  officeNumber String
  description  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  startComplexNumber Int @default(1)
  endComplexNumber   Int

  startDongNumber Int @default(1)
  endDongNumber   Int

  startFloorNumber Int @default(1)
  endFloorNumber   Int

  startHoNumber Int @default(1)
  endHoNumber   Int

  apartmentStatus JoinStatus   @default(PENDING)

  users           User[]
  residents       Resident[]
  notices         Notice[]
  complaints      Complaint[]
  votes           Vote[]
  voteRecords     VoteRecord[]
}

model User {
  id         String     @id @default(uuid())
  username   String     @unique
  password   String
  contact    String
  name       String
  email      String     @unique
  image      String?
  role       Role
  joinStatus JoinStatus @default(PENDING)
  dong       String?
  ho         String?

  apartmentId String?
  apartment   Apartment? @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  resident   Resident?
  
  notices    Notice[]
  complaints Complaint[]
  comments   Comment[]
  votes      Vote[]
  myVotes    VoteRecord[]
}

model Resident {
  id            String            @id @default(uuid())
  dong          String
  ho            String
  name          String
  contact       String
  isHouseholder HouseHolderStatus

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  // 해당 아파트 단지 내에서 이 번호는 딱 한 명만 쓸 수 있음
  @@unique([apartmentId, contact])

  // 해당 아파트 단지 내에서 이 위치(동/호)의 이 이름은 딱 한 명임
  @@unique([apartmentId, dong, ho, name])
}

model Notice {
  id       String         @id @default(uuid())
  category NoticeCategory
  title    String
  content  String

  isImportant Boolean   @default(false)
  isSchedule  Boolean   @default(false)
  startDate   DateTime?
  endDate     DateTime?

  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  comments Comment[]
}

model Complaint {
  id        String          @id @default(uuid())
  title     String
  content   String
  isPublic  Boolean         @default(true)
  status    ComplaintStatus @default(PENDING)
  viewCount Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  comments Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  noticeId String?
  notice   Notice? @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  complaintId String?
  complaint   Complaint? @relation(fields: [complaintId], references: [id], onDelete: Cascade)
}

//주민투표
model Vote {
  id          String     @id @default(uuid())
  title       String
  content     String
  targetScope String     @default("ALL") // '101동'
  startTime   DateTime
  endTime     DateTime
  status      VoteStatus @default(SCHEDULED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  authorId String? // 누가 만들었나 
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  voteOptions VoteOption[]
  voteRecords VoteRecord[]
}

//투표항목
model VoteOption {
  id      String @id @default(uuid())
  content String

  voteId String
  vote   Vote   @relation(fields: [voteId], references: [id], onDelete: Cascade)

  selections VoteRecord[]
}

//누가 어느 투표에서 무엇을 찍었는지
model VoteRecord {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  voteId String
  vote   Vote   @relation(fields: [voteId], references: [id], onDelete: Cascade)

  voteOptionId String
  voteOption   VoteOption @relation(fields: [voteOptionId], references: [id], onDelete: Cascade)

  @@unique([userId, voteId])
}

enum Role {
  USER
  SUPER_ADMIN
  ADMIN
}

enum JoinStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HouseHolderStatus {
  HOUSEHOLDER //세대주
  MEMBER //세대원
}

enum NoticeCategory {
  INSPECTION //정기점검
  URGENT //긴급공지
  COMMUNITY //커뮤니티
  VOTE //주민투표
  ETC //기타
}

enum ComplaintStatus {
  PENDING //접수전
  IN_PROGRESS //처리중
  RESOLVED //처리완료
  REJECTED //처리불가
}

enum VoteStatus {
  SCHEDULED //투표전
  IN_PROGRESS //투표중
  CLOSED //마감
}

